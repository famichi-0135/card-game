{
  "name": "@disastar/backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit --pretty false && tsc --project test/tsconfig.json --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:schema": "auth generate --config auth.cli.ts --output src/db/schema/auth.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check",
    "db:pull": "drizzle-kit pull",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:studio": "drizzle-kit studio",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@disastar/contracts": "workspace:*",
    "@disastar/game-engine": "workspace:*",
    "better-auth": "^1.6.23",
    "drizzle-orm": "0.45.2",
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.5",
    "@disastar/eslint-config": "workspace:*",
    "auth": "1.6.23",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.4",
    "esbuild": "0.28.1",
    "eslint": "^9.39.1",
    "typescript": "^7.0.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
