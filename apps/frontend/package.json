{
  "name": "@disastar/frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc -b --pretty false",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "build:staging": "tsc -b && vite build --mode staging",
    "deploy:staging": "pnpm run build:staging && wrangler deploy --keep-vars",
    "deploy:staging:check": "pnpm run build:staging && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@disastar/contracts": "workspace:*",
    "@disastar/game-engine": "workspace:*",
    "@dnd-kit/react": "^0.5.0",
    "@tanstack/react-query": "^5.101.4",
    "better-auth": "^1.6.23",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@disastar/eslint-config": "workspace:*",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^7.0.0",
    "vite": "^8.1.1",
    "wrangler": "^4.110.0"
  }
}
